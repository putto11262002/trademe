# Local secrets for `wrangler dev`. Mirror of .env, consumed by the Worker runtime.
# Copy to `.dev.vars` and fill in. Both files are gitignored.
DATABASE_URL=postgres://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require

# Market data vendors
# Finnhub (free tier — https://finnhub.io/register)
FINNHUB_API_KEY=
# Financial Modeling Prep (free tier 250 req/day — https://financialmodelingprep.com)
FMP_API_KEY=

# AI agent
# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
VERCEL_AI_GATEWAY_KEY=
