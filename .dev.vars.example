# Local secrets for `wrangler dev`. Consumed by the Worker runtime.
# Copy to `.dev.vars` and fill in. Both files are gitignored.

# Neon Postgres — https://console.neon.tech → Project → Connection Details (pooled URL)
DATABASE_URL=postgres://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require

# Market data vendors
# Finnhub (free tier — https://finnhub.io/register)
FINNHUB_API_KEY=
# Financial Modeling Prep (free tier 250 req/day — https://financialmodelingprep.com)
FMP_API_KEY=

# AI agent
# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
VERCEL_AI_GATEWAY_KEY=

# Auth — Clerk dev instance (https://dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=sk_test_
# Clerk webhook signing secret — create webhook pointing at https://trademe-dev.sabaiscale.com/api/webhooks/clerk
# Events: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_

# CF Dev Tunnel — Cloudflare Zero Trust → Networks → Tunnels → trademe-dev → token
# Used by pnpm dev:tunnel (routes trademe-dev.sabaiscale.com → localhost:5173)
CF_DEV_TUNNEL_TOKEN=

# Internal API token signing secret — used to issue short-lived user-scoped tokens
# Generate with: openssl rand -hex 32
API_TOKEN_SECRET=

# Sandbox SDK callback origin. The analysis container calls this URL.
# Docker Desktop local default: http://host.docker.internal:3000
# Tunnel/dev-domain alternative: https://trademe-dev.sabaiscale.com
TRADEME_API_BASE_URL=http://host.docker.internal:3000
