# Vite client-side env vars. Copy to `.env.local` and fill in. Both files are gitignored.
# These are embedded into the client bundle at build time — do NOT put secrets here.

# Auth — Clerk publishable key (safe to expose to browser)
# Dev: pk_test_... from Clerk dashboard → dev instance → API Keys
# Prod: injected via VITE_CLERK_PUBLISHABLE_KEY GitHub Actions secret at build time
VITE_CLERK_PUBLISHABLE_KEY=pk_test_
